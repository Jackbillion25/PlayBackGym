{
  "name": "bitacora",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "description": "Bitácora — registro personal de entrenamiento de gym. Una idea de LUKAMON.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bitacora-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply bitacora-db --remote",
    "auth:generate": "npx @better-auth/cli generate --output ./src/server/db/auth.schema.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "deploy": "astro build && wrangler deploy",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/react": "^6.0.1",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.3.1",
    "@hono/zod-validator": "^0.9.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "nanoid": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/astro": "^1.2.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.112.0"
  }
}
