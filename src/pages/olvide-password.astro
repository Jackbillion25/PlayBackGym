---
import Base from '../layouts/Base.astro'
import ThemeToggle from '../components/layout/ThemeToggle.astro'
import Footer from '../components/layout/Footer.astro'
import AuthForms from '../components/islands/AuthForms.tsx'
---

<Base title="Recuperar contraseña — Bitácora">
  <div class="app-shell">
    <div class="topbar">
      <a href="/" class="brand">Bitácora<small>registro personal de entrenamiento</small></a>
      <div class="topbar-actions"><ThemeToggle /></div>
    </div>
    <main class="app-main" style="padding-top:8px;">
      <AuthForms mode="forgot" client:load />
    </main>
    <Footer />
  </div>
</Base>
