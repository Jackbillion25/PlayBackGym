---
import Base from '../layouts/Base.astro'
import ThemeToggle from '../components/layout/ThemeToggle.astro'
import Footer from '../components/layout/Footer.astro'
import AuthForms from '../components/islands/AuthForms.tsx'
---

<Base title="Recuperar contraseña — Play Back Gym">
  <div class="app-shell">
    <div class="topbar">
      <a href="https://playbackgym.fitness" class="brand">Play Back Gym<small>dale play a tu progreso</small></a>
      <div class="topbar-actions"><ThemeToggle /></div>
    </div>
    <main class="app-main" style="padding-top:8px;">
      <AuthForms mode="forgot" client:load />
    </main>
    <Footer />
  </div>
</Base>
