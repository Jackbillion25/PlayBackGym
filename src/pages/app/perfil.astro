---
import AppLayout from '../../layouts/AppLayout.astro'
import ProfileForm from '../../components/islands/ProfileForm.tsx'

const user = Astro.locals.user!
---

<AppLayout brand="Perfil" subtitle={user.name} back="/app" title="Perfil — Play Back Gym">
  <ProfileForm
    initial={{ name: user.name, email: user.email, phone: (user as { phone?: string | null }).phone ?? null }}
    client:load
  />
</AppLayout>
